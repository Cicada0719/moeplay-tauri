{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "sensitive",
  "description": "高风险命令显式权限（文件打开、存档备份恢复、系统自启、游戏启动、下载、外部播放器等）",
  "windows": [
    "main"
  ],
  "permissions": [
    "allow-open-path",
    "allow-backup-save",
    "allow-restore-save",
    "allow-import-database",
    "allow-export-database",
    "allow-set-autostart",
    "allow-pick-directory",
    "allow-pick-image-file",
    "allow-add-game-by-path",
    "allow-add-game-by-dialog",
    "allow-import-games-from-dir",
    "allow-scan-directory-for-games",
    "allow-preview-directory-for-games",
    "allow-import-selected-candidates",
    "allow-extract-archive-command",
    "allow-launch-game",
    "allow-restore-save-snapshot",
    "allow-delete-save-snapshot",
    "allow-restore-latest-save-snapshot-from-cloud",
    "allow-download-start",
    "allow-anime-download-episode",
    "allow-anime-launch-external-player",
    "allow-secret-set",
    "allow-secret-delete",
    "allow-comic-logout",
    "allow-upsert-activity-event",
    "allow-edit-activity-event",
    "allow-delete-activity-event",
    "allow-upsert-activity-progress",
    "allow-backfill-legacy-game-activity",
    "allow-export-activity-events",
    "allow-library-v2-apply-import",
    "allow-library-v2-launch",
    "allow-anime-provider-configure",
    "allow-anime-provider-remove",
    "allow-comic-provider-configure",
    "allow-comic-provider-remove",
    "allow-export-diagnostics-zip",
    "allow-anime-provider-pick-local-directory",
    "allow-anime-provider-open-fallback",
    "allow-ai-v2-start-structured-task",
    "allow-ai-v2-cancel-task",
    "allow-ai-changes-apply",
    "allow-ai-changes-undo",
    "allow-refresh-wallpaper-manifest",
    "allow-download-wallpaper",
    "allow-import-wallpaper",
    "allow-delete-wallpaper"
  ]
}
