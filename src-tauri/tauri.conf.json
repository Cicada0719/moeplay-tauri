{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "萌游 MoeGame",
  "version": "0.19.6",
  "identifier": "com.moeplay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "萌游 MoeGame",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https: http://127.0.0.1:* http://localhost:*; media-src 'self' https: http: blob: data:; object-src 'none'; base-uri 'self'; frame-src https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/moeplay/**",
          "$LOCALDATA/moeplay/**",
          "$APPDATA/moeplay/**",
          "$APPLOCALDATA/**",
          "$DOCUMENT/**",
          "$PICTURE/**",
          "$DOWNLOAD/**"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxNDYzNDJCRjAxODJDMzAKUldRd0xCandLelJHVVQ4NittS0tORm45Mm5iWjdYejdwNjRieWw5dUZnc2E1aW1aUGkzb3E4ZXAK",
      "endpoints": [
        "https://github.com/Cicada0719/moeplay-tauri/releases/latest/download/latest.json"
      ]
    }
  }
}
